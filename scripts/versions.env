# Single source of truth for the "current" Apple platform generation.
# Bump ONCE per WWDC (June), when Apple announces the new OS line.
#
# CURRENT_OS_GEN is the ANNOUNCED generation (betas count), not GA — the
# freshness check (check-freshness.sh) applies a one-generation grace, so
# last year's OS never flags. Apple unified iOS/iPadOS/macOS/watchOS/tvOS/
# visionOS numbering at 26 (WWDC25) and confirmed the scheme at WWDC26
# (iOS 27 / macOS 27 Golden Gate / Xcode 27).
#
# Bumping this file alone will FAIL CI on purpose: check-freshness.sh
# cross-checks that skills/shared/skill-auditor/SKILL.md's known-current
# constants mention iOS $CURRENT_OS_GEN. Update both together.
CURRENT_OS_GEN=27
CURRENT_XCODE=27
CURRENT_SWIFT_MAJOR=6
